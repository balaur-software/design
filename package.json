{
  "name": "@balaur/octant",
  "version": "0.3.0",
  "description": "OCTANT design system — pure encoder, tokens, and React components. Bun-native, no build step.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.2"
  },
  "main": "./packages/ui/src/index.ts",
  "module": "./packages/ui/src/index.ts",
  "types": "./packages/ui/src/index.ts",
  "exports": {
    ".": "./packages/ui/src/index.ts",
    "./core": "./packages/octant-core/src/index.ts",
    "./tokens": "./packages/tokens/src/index.ts",
    "./tokens/tokens.css": "./packages/tokens/src/tokens.css",
    "./tokens/fonts/*": "./packages/tokens/fonts/*",
    "./package.json": "./package.json"
  },
  "files": [
    "packages/octant-core/src",
    "packages/tokens/src",
    "packages/tokens/fonts",
    "packages/ui/src",
    "packages/ui/types",
    "!**/*.stories.tsx",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!packages/ui/src/__ssr__",
    "!packages/ui/src/screens",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun test",
    "storybook": "bun run --filter '@balaur/ui' storybook",
    "build-storybook": "bun run --filter '@balaur/ui' build-storybook",
    "test-storybook": "bun run --filter '@balaur/ui' test-storybook",
    "check:full": "bun run check && bun run test-storybook"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/bun": "^1",
    "typescript": "^5"
  }
}
